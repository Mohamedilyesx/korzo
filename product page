    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28218%2C174%2C73%2C1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    width: 20px !important; height: 20px !important;
  }
  /* Fallback: any <i> or <span> inside toggler */
  .navbar-toggler i, .navbar-toggler span.icon,
  .nav_icon, [class*="nav-icon"], [class*="nav_icon"] {
    color: var(--g) !important;
    stroke: var(--g) !important;
  }
  /* nav_icon used in Tjar mobile menu button */
  .nav_icon svg, .nav_icon i { color: var(--g) !important; stroke: var(--g) !important; fill: var(--g) !important; }

  /* Search icon / bar on mobile */
