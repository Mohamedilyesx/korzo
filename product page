        $(document).ready(function() {
            let basePrice = $('h3#price').data('main-price');
            let currencySymbol = $('h3#price').data('currency-symbol');
            let totalPrice = basePrice;

            function updateTotalPrice() {
                totalPrice = basePrice;

                $('#productOptions').find('input:checked, select').each(function() {
                    if ($(this).is('select[multiple]')) {
                        $(this).find('option:selected').each(function() {
                            const price = parseFloat($(this).val().split('<||>')[1]);

                            if (!isNaN(price)) {
                                totalPrice += price;
                            }
                        });
                    } else {
                        const value = $(this).find('option:selected').val() || $(this).val();
                        const price = parseFloat(value.split('<||>')[1]);

                        if (!isNaN(price)) {
                            totalPrice += price;
                        }
                    }
                });

                $('h3#price').attr('data-main-price', totalPrice);
                $('h3#price').html(`${totalPrice.toFixed(2)} ${currencySymbol}`);
            }

            $('#productOptions').on('change', 'input, select', function() {
                updateTotalPrice();
            });

            $(document).on('change', '#digital_cards_with_options', function() {
                let newPrice = basePrice;

                const value = $(this).val();
                if (value) {
                    const selectedOption = $(this).find('option:selected');
                    const price = selectedOption.data('price');

                    newPrice += price;
                }

                $('h3#price').attr('data-main-price', newPrice);
                $('h3#price').html(`${newPrice.toFixed(2)} ${currencySymbol}`);
            });
        });
