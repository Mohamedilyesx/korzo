#jwk-mask {
  flex: 1; height: 100%; overflow: hidden;
  -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
  mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
}
#jwk-track {
  display: inline-flex; flex-wrap: nowrap;
  height: 100%; align-items: center;
  white-space: nowrap; will-change: transform;
}
.jwk-item {
  display: inline-flex; align-items: center;
  padding: 0 26px; color: #e8dfc0;
  font-size: 13.5px; font-weight: 500; white-space: nowrap;
  direction: rtl; transition: color .2s;
}
.jwk-item:hover { color: #f5e9aa; }
.jwk-sep {
  display: inline-flex; align-items: center;
  padding: 0 4px; color: rgba(218,174,73,.45); font-size: 9px;
}
#jwk-close {
  flex: 0 0 38px; width: 38px; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: transparent; border: none; cursor: pointer;
  color: rgba(218,174,73,.6); font-size: 15px;
  transition: color .2s, opacity .2s; opacity: .65;
}
#jwk-close:hover { color: var(--g); opacity: 1; }

/* ============================================================
   NAVBAR — fixed below promo bar, glass on scroll
   ============================================================ */
nav.navbar.navbar3, .custom-navbar,
.navbar.navbar3 {
  position: fixed !important;
  top: var(--bar-h) !important;
  left: 0 !important; right: 0 !important;
  z-index: 9999 !important;
  background-color: transparent !important;
  border-bottom: none !important;
  box-shadow: none !important;
  transition: background-color .3s ease, backdrop-filter .3s ease,
              box-shadow .3s ease, top .3s ease !important;
}
/* Bar closed → navbar snaps to top */
body.jwk-bar-closed nav.navbar.navbar3,
body.jwk-bar-closed .custom-navbar,
body.jwk-bar-closed .navbar.navbar3 {
  top: 0 !important;
}
/* Scrolled → dark glass */
nav.navbar.navbar3.scrolled, .custom-navbar.scrolled,
.navbar.navbar3.scrolled {
  background-color: rgba(10,7,0,.93) !important;
  backdrop-filter: blur(18px) saturate(1.4) !important;
  -webkit-backdrop-filter: blur(18px) saturate(1.4) !important;
  border-bottom: 1px solid rgba(218,174,73,.15) !important;
  box-shadow: 0 4px 28px rgba(0,0,0,.5) !important;
}

/* Navbar text/icons */
nav.navbar.navbar3 .navbar-nav li a,
nav.navbar.navbar3 .nav-link,
nav.navbar.navbar3 a,
.custom-navbar .nav-link,
.custom-navbar a {
  color: #fff !important;
  font-weight: 600;
  transition: color .2s !important;
}
nav.navbar.navbar3 .navbar-nav li a:hover,
nav.navbar.navbar3 .nav-link:hover,
.custom-navbar .nav-link:hover,
.custom-navbar a:hover { color: var(--g) !important; }

nav.navbar.navbar3 svg, nav.navbar.navbar3 i,
.custom-navbar svg, .custom-navbar i { color: #fff !important; }
.icon-notification { background-color: var(--g) !important; color: #000 !important; }

/* Breadcrumb */
.breadcrumb { background-color: transparent !important; }
.breadcrumb-item a { color: var(--txm) !important; }
.breadcrumb-item.active { color: var(--txs) !important; }
.breadcrumb-item + .breadcrumb-item::before { color: var(--txm) !important; }

/* ============================================================
   HERO — fullscreen video (added by JS)
   ============================================================ */
.hero.hero-area, .hero-area {
  position: relative !important;
  overflow: hidden !important;
  min-height: 100vh !important;
  background-color: #000 !important;
  display: flex !important;
  align-items: center !important;
}

/* Hide Tjar's static hero image */
.hero.hero-area .hero-img-wrap { display: none !important; }

.jwk-hero-video {
  position: absolute !important;
  inset: 0 !important;
  width: 100% !important; height: 100% !important;
  object-fit: cover !important;
  z-index: 0 !important;
  pointer-events: none !important;
}
.jwk-hero-overlay {
  position: absolute !important;
  inset: 0 !important;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,.78) 0%,
    rgba(0,0,0,.3) 40%,
    rgba(0,0,0,.15) 60%,
    rgba(0,0,0,.6) 100%
  ) !important;
  z-index: 1 !important;
  pointer-events: none !important;
}
.hero.hero-area .container,
.hero.hero-area .intro-excerpt {
  position: relative !important; z-index: 2 !important;
}
.hero.hero-area .intro-excerpt h1,
.hero.hero-area .intro-excerpt h2 {
  color: #fff !important;
  text-shadow: 0 2px 24px rgba(0,0,0,.8);
}
.hero.hero-area .intro-excerpt p {
  color: #d4cbb0 !important;
  text-shadow: 0 1px 8px rgba(0,0,0,.6);
}
.hero.hero-area .intro-excerpt a,
.hero.hero-area .btn-hero,
.hero.hero-area button:not(#jwk-close) {
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl)) !important;
  border: none !important;
  color: #0a0800 !important; font-weight: 800 !important;
  border-radius: 999px !important; padding: 14px 36px !important;
  box-shadow: 0 10px 30px rgba(218,174,73,.3) !important;
  transition: transform .25s var(--ease), box-shadow .25s var(--ease) !important;
  text-decoration: none !important;
}
.hero.hero-area .intro-excerpt a:hover { transform: translateY(-3px) !important; }

/* ============================================================
   HERO bottom Splide slider (banner images below hero)
   ============================================================ */
.slider-widget-area {
  background-color: var(--bg) !important;
}
.slider-widget-area .splide__slide { background-color: transparent !important; }
.slider-widget-area .splide__arrows .splide__arrow {
  background-color: rgba(26,24,21,.8) !important;
  border: 1px solid var(--bdr) !important;
}
.slider-widget-area .splide__arrows .splide__arrow svg { fill: var(--g) !important; }

/* ============================================================
   PRODUCT CARDS  (.product-item.card2)
   CRITICAL: background-color NOT background to preserve img tags
   ============================================================ */
/* Hide ratings */
.product-item .rating-wrap,
.card2 .rating-wrap,
.d-flex.justify-content-center.align-items-center.m-0.p-0 > .rating-wrap {
  display: none !important;
}

.product-item, .card2, .product-item.card2 {
  background-color: var(--bg2) !important;  /* ← background-color, not background */
  border: 1px solid rgba(218,174,73,.14) !important;
  border-radius: 16px !important;
  box-shadow: 0 4px 16px rgba(0,0,0,.3) !important;
  transition: transform .3s var(--ease), border-color .3s var(--ease), box-shadow .3s var(--ease) !important;
}
.product-item:hover, .card2:hover {
  transform: translateY(-5px) !important;
  border-color: rgba(218,174,73,.35) !important;
  box-shadow: 0 14px 36px rgba(218,174,73,.1), 0 6px 20px rgba(0,0,0,.4) !important;
}

/* Product thumbnail - NEVER hide or filter product images */
.product-item .product-thumbnail-wrap,
.card2 .product-thumbnail-wrap {
  display: block !important;
  background-color: var(--bg3) !important;
}
.product-item img, .card2 img {
  /* NO filter, NO display:none — images must show */
  display: block !important;
}

/* Product title — h3.product-title > a.text-break */
h3.product-title,
h3.product-title a,
h3.product-title a.text-break,
.product-item .product-title,
.product-item .product-title a,
.card2 .product-title,
.card2 .product-title a {
  color: var(--txt) !important;
  font-weight: 700 !important;
  transition: color .2s !important;
}
.product-item:hover .product-title a,
.card2:hover .product-title a { color: var(--g) !important; }

/* Price */
.product-item .product-price, .card2 .product-price,
strong.product-price { color: var(--g) !important; font-weight: 700 !important; }
.product-item .old-price, .card2 .old-price {
  color: var(--txm) !important; text-decoration: line-through !important;
}

/* Cart / Wishlist buttons on cards */
.cart_btn2-border, .cart_btn2 .cart_btn2-border {
  background-color: transparent !important;
  border: 1px solid rgba(218,174,73,.45) !important;
  border-radius: 999px !important;
  color: var(--g) !important;
  transition: all .25s var(--ease) !important;
}
.cart_btn2:hover .cart_btn2-border {
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl)) !important;
  border-color: transparent !important;
  color: #0a0800 !important;
}
.cart_btn2-txt { color: inherit !important; }
.cart_btn2-icon { color: inherit !important; fill: currentColor !important; }

.add-to-wishlist-btn, .wish-icon {
  background-color: rgba(26,24,21,.85) !important;
  border: 1px solid rgba(218,174,73,.3) !important;
  color: var(--g) !important;
  border-radius: 50% !important;
}
.add-to-wishlist-btn .heart { color: var(--g) !important; }

/* ============================================================
   BRAND IMAGES — ONLY .brand-img img gets filter, NOTHING else
   ============================================================ */
.brand-area, .brand-area.widgetArea {
  background-color: transparent !important;
}
.brand-img {
  background: linear-gradient(135deg, var(--bg2), var(--bg3)) !important;
  border: 1px solid rgba(218,174,73,.15) !important;
  border-radius: 14px !important;
  padding: 14px 22px !important;
  display: flex !important; align-items: center !important; justify-content: center !important;
  transition: border-color .25s ease, box-shadow .25s ease !important;
}
.brand-img:hover {
  border-color: rgba(218,174,73,.35) !important;
  box-shadow: 0 6px 18px rgba(218,174,73,.08) !important;
}
/* ONLY brand-img images get the filter — NOT widgetArea images globally */
.brand-img img {
  filter: brightness(0) invert(1) !important;
  opacity: .9 !important;
  max-height: 150px !important; 
  width: auto !important;
  object-fit: contain !important;
  transition: opacity .25s ease !important;
}
.brand-img:hover img { opacity: .9 !important; }

/* ============================================================
   FEATURES  (.four-blocks-box .single-promo)
   Correct selectors from actual HTML
   ============================================================ */
.four-blocks, .promo-area {
  background-color: var(--bg) !important;
}
.four-blocks-grid {
  display: grid !important;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)) !important;
  gap: 20px !important;
}

.four-blocks-box { height: 100%; }

.four-blocks-box .single-promo,
.promo-area .single-promo {
  background: linear-gradient(145deg, var(--bg2), #201d19) !important;
  border: 1px solid rgba(218,174,73,.15) !important;
  border-radius: 20px !important;
  padding: 28px 24px !important;
  height: 100% !important;
  box-sizing: border-box !important;
  display: flex !important; flex-direction: column !important; align-items: center !important;
  text-align: center !important; position: relative; overflow: hidden;
  transition: transform .3s var(--ease), border-color .3s var(--ease), box-shadow .3s var(--ease) !important;
  box-shadow: 0 4px 18px rgba(0,0,0,.2) !important;
}
.four-blocks-box .single-promo::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at top, rgba(218,174,73,.05), transparent 70%);
  pointer-events: none;
}
.four-blocks-box .single-promo:hover {
  transform: translateY(-4px) !important;
  border-color: rgba(218,174,73,.3) !important;
  box-shadow: 0 12px 34px rgba(218,174,73,.1), 0 6px 18px rgba(0,0,0,.35) !important;
}

/* Icon container */
.single-promo-icon {
  display: flex !important; align-items: center !important; justify-content: center !important;
  width: 60px !important; height: 60px !important; border-radius: 16px !important;
  background-color: rgba(218,174,73,.1) !important;
  border: 1px solid rgba(218,174,73,.2) !important;
  margin-bottom: 18px !important; flex-shrink: 0 !important;
  color: var(--g) !important;
}
.single-promo-icon i { color: var(--g) !important; font-size: 26px !important; }
.single-promo-icon svg { stroke: var(--g) !important; width: 26px !important; height: 26px !important; }

/* Feature title and description */
.single-promo-contents-title,
h4.single-promo-contents-title {
  color: #fff3cf !important; font-weight: 700 !important; margin-bottom: 8px !important;
}
.single-promo-contents-para,
p.single-promo-contents-para {
  color: var(--txs) !important; font-size: 14px !important; line-height: 1.8 !important;
}

/* Section headings above features */
.four-blocks .section-head .section-title,
.four-blocks .section-title {
  color: var(--txt) !important;
}
.four-blocks .section-head .section-sub {
  color: var(--g) !important;
}

/* ============================================================
   ABOUT / INTERACTIVE BLOCK (added by JS)
   ============================================================ */
.about-area { background-color: transparent !important; }
.about-area .about-box { display: none !important; }

.jawak-interactive-block {
  padding: 80px 0;
  direction: rtl;
  background: radial-gradient(ellipse at 50% 0%, rgba(218,174,73,.07), transparent 55%),
              linear-gradient(180deg, #1a1815, #111009);
}
.jawak-section-header { text-align: center; margin-bottom: 52px; padding: 0 20px; }
.jawak-pill {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 18px; margin-bottom: 14px; border-radius: 999px;
  background: linear-gradient(180deg, #1c1810, #221a12);
  border: 1px solid rgba(218,174,73,.28);
  color: var(--g); font-weight: 700; font-size: 13px;
}
.jawak-h2 {
  color: #fff3cf !important;
  font-size: clamp(1.6rem, 3.5vw, 2.5rem) !important;
  font-weight: 800 !important; margin: 0 0 12px !important;
}
.jawak-lead { color: var(--txs); font-size: 15px; max-width: 520px; margin: 0 auto; line-height: 1.9; }

.jawak-interactive-shell {
  display: grid; grid-template-columns: 400px 1fr; gap: 28px;
  align-items: stretch; max-width: 1180px; margin: 0 auto; padding: 24px;
  background: linear-gradient(180deg, #1c1812, #111009);
  border: 1px solid rgba(218,174,73,.16); border-radius: 26px;
  box-shadow: 0 16px 40px rgba(0,0,0,.2); position: relative; overflow: hidden;
}
.jawak-interactive-shell::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(218,174,73,.32) 50%, transparent);
  pointer-events: none;
}
.jawak-media-card {
  border-radius: 20px; overflow: hidden;
  border: 1px solid rgba(218,174,73,.16); background-color: #0d0d0d; min-height: 420px;
}
.jawak-media-card video { width: 100%; height: 100%; min-height: 420px; object-fit: cover; display: block; }
.jawak-content-side { display: flex; flex-direction: column; justify-content: center; }
.jawak-top-badge {
  display: inline-flex; width: fit-content; padding: 8px 16px; margin-bottom: 12px;
  border-radius: 999px; background: linear-gradient(180deg, #1c1810, #221a12);
  border: 1px solid rgba(218,174,73,.28); color: var(--g); font-weight: 700; font-size: 13px;
}
.jawak-main-title { color: #fff3cf !important; font-size: clamp(1.4rem, 2.5vw, 2rem) !important; font-weight: 800 !important; margin: 0 0 10px !important; }
.jawak-subtitle { color: var(--txs); font-size: 14.5px; line-height: 1.9; margin: 0 0 18px; }
.jawak-tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.jawak-tab-btn {
  display: flex; align-items: center; gap: 10px;
  min-height: 58px; border-radius: 14px; padding: 12px 14px;
  background-color: rgba(255,255,255,.02); border: 1px solid rgba(218,174,73,.14);
  color: #ecd9a0; cursor: pointer; text-align: right; width: 100%;
  transition: all .25s var(--ease); font-size: 14px; font-weight: 700; font-family: inherit;
}
.jawak-tab-btn:hover { border-color: rgba(218,174,73,.26); transform: translateY(-1px); }
.jawak-tab-btn.active {
  background-color: rgba(218,174,73,.1); border-color: rgba(218,174,73,.36); color: #fff3cf;
  box-shadow: 0 6px 18px rgba(0,0,0,.12), 0 0 14px rgba(218,174,73,.07);
}
.jawak-tab-icon { display: flex; align-items: center; justify-content: center; }
.jawak-tab-icon svg { width: 22px; height: 22px; stroke: var(--g); fill: none; }
.jawak-feature-view {
  border-radius: 16px; background-color: rgba(255,255,255,.02);
  border: 1px solid rgba(218,174,73,.12); padding: 18px;
}
.jawak-feature-view.is-animating { animation: jawakFadeUp .3s var(--ease) both; }
@keyframes jawakFadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
.jawak-feature-title { color: #fff3cf !important; font-size: clamp(1.1rem, 2vw, 1.45rem) !important; font-weight: 800 !important; margin: 0 0 8px !important; }
.jawak-feature-desc { color: var(--txs); font-size: 14px; line-height: 1.9; margin: 0 0 14px; }
.jawak-buy-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  min-height: 46px; padding: 0 24px; border-radius: 999px;
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl));
  border: none; color: #0a0800 !important; font-weight: 800; font-size: 14px;
  text-decoration: none !important;
  box-shadow: 0 8px 22px rgba(218,174,73,.2);
  transition: transform .25s var(--ease), box-shadow .25s var(--ease);
}
.jawak-buy-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(218,174,73,.32); color: #0a0800 !important; }

@media (max-width: 1100px) {
  .jawak-interactive-shell { grid-template-columns: 1fr; max-width: 660px; }
  .jawak-media-card, .jawak-media-card video { min-height: 260px; }
}
@media (max-width: 768px) {
  .jawak-interactive-block { padding: 48px 0; }
  .jawak-interactive-shell { padding: 14px; gap: 16px; }
}

/* ============================================================
   FAQ  — Alpine.js based (NOT Bootstrap accordion)
   Selectors from actual HTML: .faq-item > .faq-button > .faq-question / .faq-answer
   ============================================================ */
.faq-widget-section { background-color: transparent !important; }
.faq-widget { max-width: 700px !important; margin: 0 auto !important; padding: 0 16px !important; }

/* FAQ header icon area */
.lina-icon-wrap { color: var(--g) !important; }
.lina-glow {
  position: absolute; inset: 0; border-radius: 50%;
  box-shadow: 0 0 20px rgba(218,174,73,.3); background: rgba(218,174,73,.06);
}
.lina-star { color: rgba(218,174,73,.5) !important; fill: currentColor !important; }
.lina-icon svg { stroke: var(--g) !important; }

.faq-title { color: var(--txt) !important; }
.faq-subtitle { color: var(--txm) !important; }

/* FAQ list — all items equal width */
.faq-list {
  list-style: none !important; padding: 0 !important; margin: 0 !important;
  display: flex !important; flex-direction: column !important; gap: 10px !important;
}

.faq-item {
  background-color: var(--bg2) !important;
  border: 1px solid rgba(218,174,73,.15) !important;
  border-radius: 14px !important;
  overflow: hidden !important;
  width: 100% !important;
  box-sizing: border-box !important;
  transition: border-color .2s ease, box-shadow .2s ease !important;
}
.faq-item:hover {
  border-color: rgba(218,174,73,.28) !important;
  box-shadow: 0 4px 16px rgba(218,174,73,.06) !important;
}

/* faq-button = the clickable row */
.faq-button {
  display: flex !important;
  align-items: center !important;
  gap: 12px !important;
  padding: 16px 18px !important;
  cursor: pointer !important;
  background-color: var(--bg2) !important;
  border: none !important;
  width: 100% !important;
  box-sizing: border-box !important;
  text-align: right !important;
  direction: rtl !important;
  transition: background-color .2s ease !important;
}
.faq-button:hover { background-color: rgba(255,255,255,.02) !important; }
.faq-button > span svg { stroke: rgba(218,174,73,.6) !important; flex-shrink: 0 !important; }
.faq-button.open > span svg { stroke: var(--g) !important; }

.faq-question {
  color: #f0e8cc !important;
  font-weight: 700 !important;
  font-size: 14.5px !important;
  display: block !important;
  margin-bottom: 0 !important;
  background-color: transparent !important;
}
.faq-button.open .faq-question,
.faq-question.open { color: var(--g) !important; }

.faq-answer {
  color: var(--txs) !important;
  font-size: 14px !important;
  line-height: 1.9 !important;
  padding: 0 18px 16px 18px !important;
  background-color: var(--bg2) !important;
}

/* ============================================================
   FOOTER
   ============================================================ */
.store-section.footer-store-section, footer, .footer-area {
  background-color: var(--bg4) !important;
  position: relative !important;
}

 .store-section.footer-store-section, .col-lg-12 {
        color: #ffffff;
    }

.store-section.footer-store-section::before, footer::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--g) 30%, var(--gl) 50%, var(--g) 70%, transparent);
  box-shadow: 0 0 18px rgba(218,174,73,.28);
}
/* Footer section titles — gold & prominent */
.store-section.footer-store-section h4,
.store-section.footer-store-section h5,
.store-section.footer-store-section h3,
.store-section.footer-store-section .footer-widget-title,
.store-section.footer-store-section .widget-title,
footer h4, footer h5, footer h3,
footer .footer-widget-title, footer .widget-title {
  color: var(--g) !important;
  font-weight: 800 !important;
  font-size: 15px !important;
  padding-bottom: 10px !important;
  border-bottom: 1px solid rgba(218,174,73,.14) !important;
  margin-bottom: 14px !important;
}
.store-section.footer-store-section a, footer a { color: #ffffff !important; }
.store-section.footer-store-section a:hover, footer a:hover { color: var(--g) !important; }
.store-section.footer-store-section p,
.store-section.footer-store-section span,
footer p, footer span,
footer li { color: var(--txm) !important; }

.store-section.footer-store-section p, .store-section.footer-store-section span, footer p, footer span, footer li {
    color: #ffffff !important;
}
    .store-section.footer-store-section.justify-content-lg-start {
        color: #eacc6b;
    }

/* Social icons */
.footer-social a, .social-links a {
  display: inline-flex !important; align-items: center !important; justify-content: center !important;
  width: 38px !important; height: 38px !important; border-radius: 8px !important;
