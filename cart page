nav.navbar.navbar3 .nav-link:hover,
.custom-navbar .nav-link:hover,
.custom-navbar a:hover { color: var(--g) !important; }

nav.navbar.navbar3 svg, nav.navbar.navbar3 i,
.custom-navbar svg, .custom-navbar i { color: #fff !important; }
