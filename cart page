                    'quantity': qty,
                    'variant_id': variant_id
                },
                beforeSend: function (){
                    $('.loader').show();
                },
                success: function (data){
                    if (data.type === 'success')
                    {
                        toastr.success(data.msg);
                        $('#cart_tbody').html(data.markup);
                        $('.coupon-contents').html(data.cart_price_markup);
                    }
                    else if(data.quantity_msg)
