/* ============================================================
   RESPONSIVE — MOBILE FIRST
   Tjar bottom nav bar height ≈ 60px — everything must respect it.
   ============================================================ */

/* ── Tablet & Mobile — Navbar dark background ──────── */
/* On tablet/mobile Tjar forces gold background — override to dark */
@media (max-width: 991px) {

  /* Navbar: always dark on mobile/tablet (never gold) */
  nav.navbar.navbar3, .custom-navbar, .navbar.navbar3 {
    background-color: rgba(12, 9, 0, 0.97) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom: 1px solid rgba(218,174,73,.14) !important;
    box-shadow: 0 2px 16px rgba(0,0,0,.5) !important;
  }
  /* Scrolled = same dark on mobile */
  nav.navbar.navbar3.scrolled, .custom-navbar.scrolled {
    background-color: rgba(8, 6, 0, 0.99) !important;
  }

  /* Hamburger toggle button */
  .navbar-toggler {
    border: 1px solid rgba(218,174,73,.35) !important;
    border-radius: 8px !important;
    padding: 6px 10px !important;
    background-color: transparent !important;
  }
  .navbar-toggler:focus { box-shadow: 0 0 0 2px rgba(218,174,73,.2) !important; }
  /* Hamburger bars icon */
  .navbar-toggler-icon {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28218%2C174%2C73%2C1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    width: 20px !important; height: 20px !important;
  }
  /* Fallback: any <i> or <span> inside toggler */
  .navbar-toggler i, .navbar-toggler span.icon,
  .nav_icon, [class*="nav-icon"], [class*="nav_icon"] {
    color: var(--g) !important;
    stroke: var(--g) !important;
  }
  /* nav_icon used in Tjar mobile menu button */
  .nav_icon svg, .nav_icon i { color: var(--g) !important; stroke: var(--g) !important; fill: var(--g) !important; }

  /* Search icon / bar on mobile */
  .navbar-input input, .searchbar-suggetions input {
    background-color: rgba(218,174,73,.08) !important;
    border: 1px solid rgba(218,174,73,.2) !important;
    color: #fff !important;
  }
  .navbar-input input::placeholder, .searchbar-suggetions input::placeholder {
    color: rgba(218,174,73,.5) !important;
  }
  .navbar-input svg, .searchbar-suggetions svg,
  .navbar-input i, .searchbar-suggetions i {
    color: var(--g) !important; stroke: var(--g) !important;
  }

  /* All nav icons (cart, wishlist, account, search) */
  nav.navbar.navbar3 .icon-track-navbar svg,
  nav.navbar.navbar3 .icon-track-navbar i,
  .custom-navbar .icon-track-navbar svg,
  .custom-navbar .icon-track-navbar i {
    color: var(--g) !important;
    stroke: var(--g) !important;
  }
  /* Cart count badge */
  .icon-notification {
    background-color: var(--g) !important;
    color: #000 !important;
    font-weight: 700 !important;
  }

  /* Logo */
  nav.navbar.navbar3 .navbar-brand img,
  .custom-navbar .navbar-brand img {
    filter: none !important;
    opacity: 1 !important;
  }

  /* Interactive block */
  .jawak-interactive-shell {
    grid-template-columns: 1fr !important;
    max-width: 660px !important;
  }
  .jawak-media-card,
  .jawak-media-card video { min-height: 260px !important; }

  /* Features */
  .four-blocks-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important;
  }
}

