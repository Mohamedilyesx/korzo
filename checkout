/* ============================================================
   TJAR MOBILE BOTTOM NAVIGATION — Dark Gold Theme
   Classes confirmed from real HTML: .mobile-nav, .mobile-nav-item,
   .mobile-nav-link, .mobile-nav-icon, .mobile-nav-title, .icon-count
   ============================================================ */

/* Container */
div.mobile-nav:not(.opacity-0) {
  background-color: #231c06 !important;
  border-top: 1px solid rgba(218,174,73,.28) !important;
  box-shadow: 0 -4px 24px rgba(0,0,0,.6) !important;
}

/* Each nav item */
div.mobile-nav:not(.opacity-0) .mobile-nav-item {
  position: relative !important;
  flex: 1 1 0 !important;
}

/* Link wrapper */
div.mobile-nav:not(.opacity-0) .mobile-nav-link {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 3px !important;
  padding: 8px 4px !important;
  color: rgba(218,174,73,.55) !important;
  text-decoration: none !important;
  transition: color .2s ease !important;
  position: relative !important;
}

/* Hover & active */
div.mobile-nav:not(.opacity-0) .mobile-nav-link:hover,
div.mobile-nav:not(.opacity-0) .mobile-nav-link.active,
div.mobile-nav:not(.opacity-0) .mobile-nav-link[class*="active"],
div.mobile-nav:not(.opacity-0) .mobile-nav-item.active .mobile-nav-link {
  color: #daae49 !important;
}

/* Gold top-indicator bar on active */
div.mobile-nav:not(.opacity-0) .mobile-nav-link.active::before,
div.mobile-nav:not(.opacity-0) .mobile-nav-item.active .mobile-nav-link::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important; left: 20% !important; right: 20% !important;
  height: 2px !important;
  background: linear-gradient(90deg, #b88b3c, #daae49, #f0d878) !important;
  border-radius: 0 0 4px 4px !important;
}

/* Icons */
div.mobile-nav:not(.opacity-0) .mobile-nav-icon {
  font-size: 22px !important;
  line-height: 1 !important;
  position: relative !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}
div.mobile-nav:not(.opacity-0) .mobile-nav-icon i {
  font-size: 22px !important;
  color: inherit !important;
}

/* Labels */
div.mobile-nav:not(.opacity-0) .mobile-nav-title {
  font-size: 10px !important;
  font-weight: 500 !important;
  color: inherit !important;
  white-space: nowrap !important;
  font-family: 'Cairo', 'Tajawal', sans-serif !important;
}

/* Badge (cart / wishlist count) */
