        .checkout .input-group .input-group-text{
            background: #fff;
            border-radius: 8px;
        }
        [dir=rtl] .checkout .input-group .input-group-text{
            border-left-width: 0;
            border-radius: 0 8px 8px 0 !important
        }

        .form-check{
            padding: 0;
        }
        .form-check .form-label{
            display: inline;
            margin: 0 0 0 6px;
        }
        [dir=rtl] .form-check .form-label{
            margin: 0 6px 0 0;
        }
        .form-check .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            margin: 4px 0 0 !important;
            float: none !important;
            box-shadow: none !important;
