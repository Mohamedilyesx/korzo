<script src="/livewire/livewire.js?id=e2b302e9"   data-csrf="69t9UlksK9A2da1i5F9RhJ2wdNuEcyCXywBlM1D9" data-update-uri="/tjar/livewire/update" data-navigate-once="true"></script>

<!-- Google Maps API -->
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBZ0gm-Y7RzCQyNvk-tXB0o0VMRzfY_dhM&libraries=places" defer async></script>
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.7/build/js/intlTelInput.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js"></script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
    let tabs = {
        'inputForm': 'inputForm',
        'OTPForm': 'OTPForm',
        'inputNameForm': 'inputNameForm'
    }

    let signInTypes = ['phone', 'email']

    let inputTelInputLib = window.intlTelInput

    const errorMap = ['الرجاء إدخال رقم جوال صحيح', 'رمز البلد غير صالح', 'قصير جدًا', 'طويل جدًا', 'الرجاء إدخال رقم جوال صحيح'];

    document.addEventListener('alpine:init', () => {
        Alpine.data('loginForm', () => ({
            inputTelInputLib,
            initializeTelInput : null,
            isSaudi: true,
            enableMultiCountryLogin: false,
            enableEmailLogin: false,
            currentTab: tabs.inputForm,
            signInUsing: '' ? signInTypes[1] : signInTypes[0],
            metadata: {
                changeLoading: false,
                inputLoading: false,
                otpLoading: false,
                inputNameLoading: false
            },
            sessionMobile: parseInt('0'),
            sessionEmail: parseInt('0'),
            stepOneOk: parseInt('0') ?? 0,
            stepTwoOk: parseInt('1') ?? 0,
            stepThreeOk: parseInt('1') ?? 0,
            otpSteps: {
                first: null,
                second: null,
                third: null,
                fourth: null
            },
            errors: null,
            inputForm: {
                email: '' ? '' : null,
                phone: null,
                cloudflareCaptcha: null,
            },
            OTPForm: {
                otp: null,
            },
            inputNameForm: {
                name: null,
                phone: '',
                email: '',
            },
            timer: 0,
            timerInterval: null,
            otpSuccess: false,

            // Getters
            get otp1Value() {
                return this.otpSteps.first;
            },
            get otp2Value() {
                return this.otpSteps.second;
            },
            get otp3Value() {
                return this.otpSteps.third;
            },
            get otp4Value() {
                return this.otpSteps.fourth;
            },
            get otpValue() {
                return `${this.otp1Value ?? ''}${this.otp2Value ?? ''}${this.otp3Value ?? ''}${this.otp4Value ?? ''}`;
            },
            get otpFilled() {
                return this.otp1Value && this.otp2Value && this.otp3Value && this.otp4Value
            },
            get timerStarted() {
                return this.timerInterval !== null
            },
            get timerText() {
                return `${this.timer}s`
            },
            get inputFormPhone() {
                return this.inputForm.phone
            },

            // Functions
            getError(name = '') {
                return this.errors != null && name in this.errors ? (this.errors[name][0] ?? null) : null
            },

            initPhoneInput() {
                if((this.currentTab === tabs.inputForm || this.currentTab === tabs.inputNameForm)) {
                    this.$nextTick(() => {
                        document.querySelectorAll("[data-tel-input='ture']").forEach((phone) => {
                            if (phone.dataset.initiated === "true") return;

                            const oldValue = phone.value;
                            phone.value = '';

                            if (phone.classList.contains("iti")) {
                                const iti = window.intlTelInputGlobals.getInstance(phone);
                                if (iti) {
                                    iti.destroy();
                                }
                            }

                            if(this.enableMultiCountryLogin){
                                this.initializeTelInput = this.inputTelInputLib(phone, {
                                    initialCountry: "auto",
                                    geoIpLookup: callback => {
                                        fetch("https://ipapi.co/json")
                                            .then(res => res.json())
                                            .then(data => callback(data.country_code))
                                            .catch(() => callback('sa'))
                                    },
                                    utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.7/build/js/utils.js",
                                    strictMode: true,
                                    separateDialCode: true,
                                    i18n: {
                                        searchPlaceholder: 'بحث'
                                    } 
                                });

                                phone.addEventListener('countrychange', () => {
                                    let data = this.initializeTelInput.getSelectedCountryData();
                                    this.isSaudi = data.iso2 == 'sa' ? true : false;
                                });

                            }else{
                                this.initializeTelInput = this.inputTelInputLib(phone, {
                                    initialCountry: "sa",
                                    onlyCountries: ["sa"],
                                    utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.7/build/js/utils.js",
                                    strictMode: true,
                                    separateDialCode: true
                                });
                            }

                            if(oldValue || this.inputNameForm.phone){
                                let val = this.inputFormPhone.phone || oldValue;
                                this.initializeTelInput.setNumber(val);
                            }

                            phone.dataset.initiated = "true";
                        });
                    });
                }
            },

            async saveInformation() {
                if (this.metadata.inputNameLoading) return;

                let number = this.inputNameForm.phone?.replace(/[\s-]/g, '')

                if ((this.inputNameForm.phone !== '') && !/^\d{9}$/.test(String(number))) {
                    if(this.enableMultiCountryLogin){
                        if (this.initializeTelInput != null) {
                            if(!this.initializeTelInput.isValidNumber()){
                                const errorCode = this.initializeTelInput.getValidationError();
                                const msg = errorMap[errorCode] || 'الرجاء إدخال رقم جوال صحيح';
                                this.errors = {
                                    mobile: [msg]
                                };
                                toastr.error(errorMap[errorCode]);
                                return;
                            }else{
                                number = this.initializeTelInput.getNumber();
                            }
                        }
                    }else{
                        if(!/^\d{9}$/.test(String(number))){
                            this.errors = {
                                mobile: [
                                    'الرجاء إدخال رقم جوال صحيح'
                                ]
                            }
                            toastr.error('الرجاء إدخال رقم جوال صحيح')
                            return;
                        }
                    }
                }

                this.errors = null;
                this.metadata.inputNameLoading = true;
                try {
                    const response = await fetch('https://jawaktv.com/v_ql_step3', {
                        method: 'POST',
                        headers: {
                            "Content-type": "application/json; charset=UTF-8",
                            "X-Requested-With": 'XMLHttpRequest',
                            "X-CSRF-TOKEN": "69t9UlksK9A2da1i5F9RhJ2wdNuEcyCXywBlM1D9"
                        },
                        body: JSON.stringify({
                            ...this.inputNameForm,
                            mobile: this.inputNameForm.phone
                        })
                    })
                    const data = await response.json();

                    if(response.ok) {
                        window.location.reload()
                    } else {
                        if (response.status === 401) {
                            window.location.reload();
                        }
                        toastr.error(data.message)
                        this.errors = {...data.errors}
                        this.metadata.inputNameLoading = false;
                    }
                } catch (e) {
                    console.error(e)
                    this.metadata.inputNameLoading = false;
                }
            },

            async changeNumber() {
               if (this.metadata.changeLoading) return;

               this.errors = null;
               this.metadata.changeLoading = true;

               try {
                   const response = await fetch('https://jawaktv.com/v_ql_change_number', {
                       method: 'POST',
                       headers: {
                           "Content-type": "application/json; charset=UTF-8",
                           "X-Requested-With": 'XMLHttpRequest',
                           "X-CSRF-TOKEN": "69t9UlksK9A2da1i5F9RhJ2wdNuEcyCXywBlM1D9"
                       },
                   })

                   const data = await response.json();

                   if(response.ok) {
                       this.currentTab = tabs.inputForm
                   } else {
                       toastr.error(data.message)
                       this.errors = {...data.errors}
                   }
               } catch (e) {
                   console.error(e)
               } finally {
                   this.metadata.changeLoading = false;
               }
            },

            async submitStepOne(resendOtp = false) {
                if(this.metadata.inputLoading) return;

                let number = this.inputForm.phone?.replace(/[\s-]/g, '')

                if (this.signInUsing === signInTypes[0]) {
                    if(this.enableMultiCountryLogin){
                        if(!this.initializeTelInput.isValidNumber()){
                            const errorCode = this.initializeTelInput.getValidationError();
                            const msg = errorMap[errorCode] || 'الرجاء إدخال رقم جوال صحيح';
                            this.errors = {
                                mobile: [msg]
                            };
                            toastr.error(errorMap[errorCode]);
                            return;
                        }else{
                            number = this.initializeTelInput.getNumber();
                        }
                    }else{
                        if(!/^\d{9}$/.test(String(number))){
                            this.errors = {
                                mobile: [
                                    'الرجاء إدخال رقم جوال صحيح'
                                ]
                            }
                            toastr.error('الرجاء إدخال رقم جوال صحيح')
                            return;
                        }
                    }
                }

                this.errors = null;
                this.metadata.inputLoading = true

                try {
                    let params = {}

                    if(this.signInUsing === signInTypes[1]) {
                        params['email'] = this.inputForm.email
                        params['captcha'] = this.inputForm.cloudflareCaptcha ?? null;
                    } else if (this.signInUsing === signInTypes[0]) {
                        params['mobile'] = this.inputForm.phone
                    }

                    const response = await fetch('https://jawaktv.com/_ql', {
                        method: 'POST',
                        headers: {
                            "Content-type": "application/json; charset=UTF-8",
                            "X-Requested-With": 'XMLHttpRequest',
                            "X-CSRF-TOKEN": "69t9UlksK9A2da1i5F9RhJ2wdNuEcyCXywBlM1D9"
                        },
                        body: JSON.stringify({
                            ...params,
                            mobile: number,
                            is_email: this.signInUsing === signInTypes[1],
                            is_resend: resendOtp
                        })
                    });
                    const data = await response.json()

                    if(response.ok) {
                        toastr.success(data.message);
                        this.currentTab = tabs.OTPForm

                        if(this.signInUsing === signInTypes[1]) {
                            this.sessionEmail = true
                            this.sessionMobile = false
                        } else if(this.signInUsing === signInTypes[0]) {
                            this.sessionEmail = false
                            this.sessionMobile = true
                        }

                    } else {
                        toastr.error(data.message);
                        this.errors = {...data.errors}

                        if (response.status === 419) {
                            setTimeout(() => {
                                window.location.reload();
                            }, 1000);
                        }

                        if (response.status === 401) {
                            window.location.reload();
                        }
                    }

                } catch (e) {
                    console.error(e)
                } finally {
                    this.metadata.inputLoading = false
                }
            },

            startTimer() {
                clearInterval(this.timerInterval)
                this.timerInterval = null

                this.timer = 60;
                this.timerInterval = setInterval(() => {
                    if(this.timer <= 0) {
                        clearInterval(this.timerInterval)
                        this.timerInterval = null
                    } else
                        this.timer -= 1;
                }, 1000)
            },

            async checkOTP() {
                if(this.metadata.otpLoading) return;

                this.errors = null;
                this.metadata.otpLoading = true

                try {
                    this.metadata.otpLoading = true

                    const response = await fetch('https://jawaktv.com/v_ql', {
                        method: 'POST',
                        headers: {
                            "Content-type": "application/json; charset=UTF-8",
                            "X-Requested-With": 'XMLHttpRequest',
                            "X-CSRF-TOKEN": "69t9UlksK9A2da1i5F9RhJ2wdNuEcyCXywBlM1D9"
                        },
                        body: JSON.stringify({
                            otp: this.otpValue
                        })
                    });
                    const data = await response.json();

                    if(response.ok) {
                        this.otpSuccess = true
                        if(response.status === 202) {
                            this.currentTab = tabs.inputNameForm

                            if(this.signInUsing === signInTypes[0]) {
                                this.inputNameForm.phone = this.inputForm.phone
                            } else if(this.signInUsing === signInTypes[1]) {
                                this.inputNameForm.email = this.inputForm.email
                            }
                        } else {
                            window.location.reload()
                        }
                    } else {
                        this.errors = {...data.errors} ?? null
                        toastr.error(data.message)
                        this.$refs.otp4?.focus()
                        this.metadata.otpLoading = false

                        if (response.status === 419) {
                            setTimeout(() => {
                                window.location.reload();
                            }, 1000);
                        }

                        if (response.status === 401) {
                            window.location.reload();
                        }
                    }
                } catch (e) {
                    this.metadata.otpLoading = false
                    console.error(e)
                }
            },

            checkActiveTabBySession() {
                if(!this.stepOneOk) {
                    this.currentTab = tabs.inputForm
                }

                else if(this.stepOneOk && !this.stepTwoOk) {
                    this.currentTab = tabs.OTPForm
                }

                else if(this.stepOneOk && this.stepTwoOk && !this.stepThreeOk) {
                    this.currentTab = tabs.inputNameForm
                }

                else
                    this.currentTab = tabs.inputForm
            },

            fillOTPFromDigits(value = '') {
                const data = String(value).replace(/\D/g, '').slice(0, 4);

                if (data.length) {
                    this.otpSteps.first = data[0] ?? null;
                    this.otpSteps.second = data[1] ?? null;
                    this.otpSteps.third = data[2] ?? null;
                    this.otpSteps.fourth = data[3] ?? null;

                    this.$nextTick(() => {
                        const nextInput = this.$refs[`otp${Math.min(data.length + 1, 4)}`];
                        nextInput?.focus();

                        if (this.otpFilled) this.checkOTP();
                    });
                }
            },

            handlePasteOTP(event) {
                const data = event.clipboardData.getData('Text');
                if (data) {
                    this.fillOTPFromDigits(data);
                }

                event.preventDefault();
            },

            handleOTPInput(event, step) {
                const value = event.target.value.replace(/\D/g, '');

                if (value.length > 1) {
                    this.fillOTPFromDigits(value);
                    return;
                }

                this.otpSteps[step] = value || null;
                event.target.value = value;
            },

            renderCloudflare() {
                let $this = this;

                $this.$nextTick(() => {
                    if ($this.$refs.cloudflareCaptcha) {
                        turnstile.render(this.$refs.cloudflareCaptcha, {
                            sitekey: '0x4AAAAAABACfqNbiXC_ADiW',
                            theme: 'light',
                            callback: (token) => {
                                $this.inputForm.cloudflareCaptcha = token;
                            }
                        });
                    }
                })
            },

            async init() {
                this.checkActiveTabBySession()

                let $this = this

                this.$watch('currentTab', function () {
                    $this.errors = null
                    this.otpSuccess = false
                    $this.initPhoneInput()

                    if($this.currentTab === tabs.OTPForm)
                        $this.startTimer()
                })

                this.$watch('signInUsing', function(val) {
                    $this.errors = null
                    $this.initPhoneInput()

                    // if (val === 'email' && '') {
                    //     $this.renderCloudflare();
                    // }
                })

                this.$watch('otp1Value', (val) => {
                    if(val)
                        $this.$refs.otp2?.focus()
                    else
                        $this.otpSteps.first = null
                })

                this.$watch('otp2Value', (val) => {
                    if(val)
                        $this.$refs.otp3?.focus()
                    else
                        $this.$refs.otp1?.focus()
                })

                this.$watch('otp3Value', (val) => {
                    if(val)
                        $this.$refs.otp4?.focus()
                    else
                        $this.$refs.otp2?.focus()
                })

                this.$watch('otp4Value', (val) => {
                    if(val) {
                        $this.$refs.otp4?.blur()
                        if($this.otpFilled)
                            this.checkOTP()
                    } else {
                        $this.$refs.otp3?.focus()
                    }
                })

                this.$watch('inputFormPhone', val => {
                    if(val === '' || val === null)
                        return;

                    let num = val.replaceAll(' ', '')
                    let isZero = num.length ? parseInt(num.charAt(0)) === 0 : false
                    if(isZero) {
                        this.inputForm.phone = num.split('').splice(1, num.length - 1).join('')
                    }
                })

                this.$nextTick(() => {
                    $this.initPhoneInput()
                })

                if(this.currentTab === tabs.OTPForm)
                    this.startTimer()

                if(this.inputNameForm.phone) {
                    this.inputNameForm.phone = this.inputNameForm.phone.substring(3, this.inputNameForm.phone.length)

                    const prefixes = ['+966','966','05','5']; 
                    this.isSaudi = prefixes.some(prefix => this.inputNameForm.phone.startsWith(prefix));
                }
            }
        }))
    })
