        #notes{
            resize: none;
        }
        #notes::placeholder{
            color: var(--bs-gray-600);
        }

        .checkout .btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border-radius: 8px;
            font-weight: 600;
            line-height: 1
        }
        .checkout .btn-lg{
            width: 100%;
            padding: 14px 16px;
        }
        .checkout .btn i{padding: 0;}
        .btn-light-primary{
            position: relative;
            color: var(--main-color-one) !important;
            overflow: hidden;
        }
        .btn-light-primary::before{
            content: '';
            width: 100%;
            height: 100%;
            background: var(--main-color-one);
            position: absolute;
            top: 0; left: 0;
            opacity: .1;
        }
        .btn-light-danger{
            background: #dc354510;
            color: #dc3545 !important;
        }
        .btn-border-main{
            background: none;
            color: var(--main-color-one) !important;
            border: 1px solid var(--main-color-one);
        }
        .custom_radio {
            box-shadow: 0 0 0 1px var(--ch-border);
            font-size: 3em;
            width: 16px;
            min-width: 16px;
            height: 16px;
            margin: 2px;
            border-radius: 50%;
            appearance: none;
            transition: background .3s, box-shadow .3s;
            cursor: pointer;
        }
        .custom_radio:hover {
            box-shadow: 0 0 0 1px var(--main-color-one), inset 0 0 1.5rem -1rem var(--main-color-one);
        }
        .custom_radio:disabled {
            pointer-events: none;
            box-shadow: 0 0 0 1px var(--ch-border), inset 0 0 0 2rem #F2F4F7;
            opacity: .5;
        }
        .custom_radio:checked {
            box-shadow: 0 0 0 1px var(--main-color-one);
            background-color: var(--main-color-one);
            border: 5px solid #fff;
        }
        .form-group.select2 .select2-container {
            min-width: auto;
        }
        .form-group.select2 .select2-selection,
        .select2-container--open .select2-dropdown,
        .select2-container--default .select2-search--dropdown .select2-search__field {
            border-color: #ced4da;
            border-radius: 8px !important;
        }
        .form-group.select2 .select2-selection__arrow:before{
            content: "\f107";
            font-family: 'Line Awesome Free';
            font-weight: 900;
        }
        .select2-results__option {
            border-radius: 8px;
        }

        .login_modal {
            backdrop-filter: blur(16px);
        }
        .sign-in .form-control {
            border-radius: 0;
        }

        .map {
            height: 300px;
        }
        .spinner-border {
            color: var(--main-color-one) !important;
        }
        .text-gray-600{
            color: var(--bs-gray-600) !important;
        }

        .checkout_head {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 32px;
            margin-bottom: 32px;
            border-radius: 24px;
            background: #fff;
            box-shadow: 0px 2px 4px 0px #0000000F;
        }

        .checkout_head .logo img {
            max-width: 160px;
            max-height: 60px;
        }
        .back_cart {
            padding: 12px;
        }
        [dir=ltr] .back_cart i{
            transform: scaleX(-1)
        }

        .checkout_cart,
        .checkout_details{
            display: flex;
            flex-direction: column;
            gap: 24px;
            padding: 32px;
            border-radius: 24px;
            background: #fff;
            box-shadow: 0px 2px 4px 0px #0000000F;
        }

        .coupon_promo-input .btn span{
            display: flex;
            gap: 6px
        }

        .step_head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
        }
        .step_head-content {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .step_head-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            min-width: 40px;
            height: 40px;
            font-size: 20px;
            background: #1ABF72;
            border-radius: 50%;
            color: #fff;
        }

        .step_body {
            padding: 24px;
            border-radius: 16px;
            background: #F8F8F8;
        }

        .step_edit-icon {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--main-color-one);
            color: #fff;
            box-shadow: inset 0 0 0 3px #fff;
            border: 1px solid var(--main-color-one);
            border-radius: 50%;
            font-size: 22px;
        }

        /* address */
        .saved_address,
        .new_address-bar{
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            background: #fff;
            border: 1px solid var(--ch-border);
            border-radius: 12px;
            padding: 16px;
        }
        .saved_address label,
        .new_address-bar,
        .new_address-bar label{
            cursor: pointer;
        }
        .new_address-bar label i{
            color: var(--main-color-one);
        }

        .edit_address-wrap {
            background: #fff;
            padding: 24px;
            border: 1px solid var(--ch-border);
            border-radius: 20px;
        }
        .address_form-wrap{
            background: #F8F8F8;
            padding: 24px;
            border: 1px solid var(--ch-border);
            border-radius: 20px;
        }

        .saved_address-action{
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .saved_address-action .btn,
        .step_head .btn{
            padding: 10px 12px;
        }

        /* shopping method */
        .shipping_card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            background: #fff;
            padding: 20px;
            border: 1px solid var(--ch-border);
            border-radius: 12px;
            cursor: pointer;
        }
        .shipping_info {
            display: flex;
            align-items: start;
            gap: 12px;
        }
        .shipping_price {
            background: #F5F5F5;
            border-radius: 8px;
            border: 1px solid #80808059;
            padding: 12px 16px;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            line-height: 1;
        }

        /* payment methods */
        .payment_tab-wrap {
            align-items: center;
            gap: 16px 0;
            border: none;
        }
        .payment_tab {
            min-width: 180px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            background: #fff;
            padding: 24px;
            border: 1px solid var(--ch-border);
            border-radius: 12px;
            box-shadow: 0px 1px 2px 0px #1018280D;
            cursor: pointer;
        }
        .payment_tab .img {
            display: flex;
            align-items: center;
            justify-content: end;
            height: 26px;
        }
        .payment_tab .img img{
            max-height: 100%;
        }
        .payment_name{
            display: flex;
            align-items: center;
            gap: 12px;
            line-height: 1.6;
        }

        .card_payment_form{
            background: #fff;
            border-radius: 12px;
        }

        .payment-form{
            background: #fff;
            border: 1px solid var(--ch-border);
            border-radius: var(--ch-round-12);
        }

        .bank_details {
            display: flex;
            align-items: center;
            justify-content: space-between;
            text-align: center;
            gap: 24px;
            background: #fff;
            padding: 24px 34px;
            border-radius: 8px;
            position: relative;
        }
        .bank_dot{
            width: 12px;
            height: 12px;
            background: var(--main-color-one);
            border-radius: 50%;
        }

        #document::file-selector-button {
            display: none;
        }

        .uploader {
            display: flex;
            justify-content: center;
            gap: 12px;
            text-align: center;
            padding: 24px;
            background: #fff;
            border-radius: 8px;
        }
        .uploader_icon {
            min-width: 45px;
            width: 45px;
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--main-color-one);
            color: #fff;
            font-size: 22px;
            border-radius: 8px;
            cursor: pointer;
        }

        .btn-popup-map {
            border-radius: 0 !important;
            line-height: normal !important;
            font-weight: 400 !important;
        }

        .pac-container {
            z-index: 9999;
        }

        [dir=ltr] .btn-search-modal {
            margin-left: 10px !important;
            border-radius: 8px !important;
        }

        .input-search-modal {
            border-radius: 8px !important;
        }

        [dir=rtl] .btn-search-modal {
            margin-right: 10px !important;
            border-radius: 8px !important;
        }

        @media(min-width:1200px){
            .checkout > .container {
                max-width: 980px;
            }
        }
        @media(min-width:992px){
            .payment_tab-wrap li:nth-last-child(2),
            .payment_tab-wrap li:last-child {
                flex: 1 0 0%;
            }
        }
        @media (min-width: 900px) {
            .checkout .container {
                padding: 0 55px;
            }
        }
        @media(min-width:768px){
            .payment_tab-wrap li:last-child {
                flex: 1 0 0%;
            }
        }
        @media (max-width: 1098px) and (min-width: 981px) {
            .checkout .container {
                padding: 0 70px;
            }
        }
        @media(max-width:767px){
            *{
                --ch-round-12: 8px;
            }
            .checkout{
                padding: 60px 0;
            }
            .container{
                max-width: 100% !important;
                padding: 0 24px;
            }
            .custom_radio{
                width: 16px;
                min-width: 16px;
                height: 16px;
                border: 4px solid #fff
            }
            .checkout_head,
            .checkout_cart,
            .checkout_details{
                padding: 20px;
                border-radius: 16px;
            }
            .checkout_head .logo img {
                max-width: 120px;
                max-height: 50px;
            }

            .step_head,
            .saved_address,
            .new_address-bar:not(.flex-row),
            .shipping_card {
                flex-direction: column;
                align-items: start !important;
            }
            .step_head-content{
                /* align-items: start; */
                gap: 12px;
            }
            .step_head-icon {
                width: 32px;
                min-width: 32px;
                height: 32px;
                font-size: 16px;
            }
            .step_head .btn{
                width: 100%;
                padding: 10px;
            }
            .step_body {
                padding: 20px 16px;
            }

            .edit_address-wrap,
            .address_form-wrap {
                padding: 18px;
                border-radius: 16px;
            }

            .shipping_card {
                padding: 16px;
            }
            .shipping_price{
                width: 100%;
            }

            .payment_tab .img {
                height: 20px;
            }
            .payment_tab {
                min-width: 100%;
                gap: 12px;
                padding: 18px;
                border-radius: 8px;
            }

            .card_payment_form{
                background: none;
                border-radius: 0;
            }
            .bank_details {
                align-items: start;
                text-align: start;
                flex-direction: column;
                padding: 18px;
            }
            .bank_dot{
                display: none;
            }
            .uploader {
                flex-direction: column-reverse;
            }
            .uploader_icon {
                width: 100%;
            }
        }
