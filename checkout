/* ============================================================
   USER DASHBOARD — /user-home — Dark Gold Theme
   Classes confirmed from real HTML source.
   External CSS: user-dashboard.css (overridden here)
   ============================================================ */

/* ── Page & section wrapper ── */
.dash_section {
  background-color: var(--bg) !important;
  min-height: 100vh !important;
}
.dash_container { background-color: transparent !important; }

/* ── Main head card (cover + welcome + menu) ── */
.dash_head {
  background-color: var(--bg2) !important;
  border: 1px solid rgba(218,174,73,.14) !important;
  border-radius: 24px !important;
  box-shadow: 0 6px 32px rgba(0,0,0,.4) !important;
  overflow: hidden !important;
}

/* ── Cover / banner area ── */
.dash_user-cover {
  background-color: var(--bg3) !important;
  border-bottom: 1px solid rgba(218,174,73,.12) !important;
  position: relative !important;
}
/* Decorative inner cover — subtle gold tint */
.dash_inner-cover {
  background-image: none !important;
  background: linear-gradient(135deg,
    rgba(184,139,60,.08) 0%,
    rgba(218,174,73,.05) 50%,
    rgba(10,8,0,.2) 100%) !important;
  border-bottom: 1px solid rgba(218,174,73,.1) !important;
}
/* Decorative background */
.dash_user-bg {
  background: radial-gradient(ellipse at 60% 50%,
    rgba(218,174,73,.06) 0%,
    transparent 70%) !important;
}
/* Shadow circle decoration */
.shadow_circle i {
  background: rgba(218,174,73,.05) !important;
}

/* ── Profile image ring ── */
.dash_user-img {
  border: 3px solid rgba(218,174,73,.4) !important;
  border-radius: 50% !important;
  box-shadow: 0 0 0 4px var(--bg2), 0 0 20px rgba(218,174,73,.15) !important;
}
.dash_user-img img {
  border-radius: 50% !important;
}

/* ── Logout button ── */
.dash_logout, .btn_2d.danger.dash_logout {
  background-color: rgba(220,53,69,.1) !important;
  border: 1px solid rgba(220,53,69,.25) !important;
  color: #e07070 !important;
  border-radius: 999px !important;
}
.dash_logout svg { fill: #e07070 !important; }
.dash_logout:hover {
  background-color: rgba(220,53,69,.2) !important;
  border-color: rgba(220,53,69,.4) !important;
}

/* ── Welcome text ── */
.dash_welcome {
  background-color: transparent !important;
  text-align: center !important;
}
.dash_welcome h2 {
  color: var(--txt) !important;
  font-size: clamp(1.2rem, 3vw, 1.6rem) !important;
}
.dash_welcome h2 .emoji { font-style: normal !important; }
.dash_welcome span {
  color: var(--txm) !important;
  font-size: 14px !important;
}

/* ── Tabs menu wrapper ── */
.dash_menu-wrap {
  background-color: transparent !important;
  border-top: 1px solid rgba(218,174,73,.1) !important;
  position: relative !important;
}

/* ── Tab list (horizontal scroll) ── */
.dash_menu-list {
  background-color: transparent !important;
  list-style: none !important;
  display: flex !important;
  gap: 4px !important;
  padding: 8px 12px !important;
  overflow-x: auto !important;
  scrollbar-width: none !important;
}
.dash_menu-list::-webkit-scrollbar { display: none !important; }

/* ── Each tab item ── */
.dash_menu-list li {
  flex-shrink: 0 !important;
}
.dash_menu-list li a {
  display: flex !important;
  align-items: center !important;
  gap: 6px !important;
  padding: 8px 14px !important;
  border-radius: 999px !important;
  color: var(--txm) !important;
  font-size: 13px !important;
  font-weight: 500 !important;
  white-space: nowrap !important;
  text-decoration: none !important;
  transition: all .2s ease !important;
  border: 1px solid transparent !important;
}
.dash_menu-list li a:hover {
  color: var(--g) !important;
  background-color: rgba(218,174,73,.08) !important;
  border-color: rgba(218,174,73,.18) !important;
}

/* ── Active tab ── */
.dash_menu-list li.active a,
.dash_menu-list li a.active {
  color: #0a0700 !important;
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl)) !important;
  border-color: transparent !important;
  font-weight: 700 !important;
  box-shadow: 0 3px 12px rgba(218,174,73,.25) !important;
}

/* ── Tab SVG icons ── */
.dash_menu-list li a svg,
.dash_menu-list li a .default_icon,
.dash_menu-list li a .activ_icon {
  width: 16px !important;
  height: 16px !important;
  flex-shrink: 0 !important;
}
/* Normal tab: icon muted gold */
.dash_menu-list li:not(.active) a svg,
.dash_menu-list li:not(.active) a .default_icon {
  fill: var(--txm) !important;
  color: var(--txm) !important;
}
/* Active tab: icon dark (on gold bg) */
.dash_menu-list li.active a svg,
.dash_menu-list li.active a .activ_icon {
  fill: #0a0700 !important;
  color: #0a0700 !important;
}
/* Show/hide logic: default shows default_icon, active shows activ_icon */
.dash_menu-list li:not(.active) .activ_icon { display: none !important; }
.dash_menu-list li.active .default_icon { display: none !important; }
.dash_menu-list li.active .activ_icon { display: inline-block !important; }

/* ── Scroll arrows ── */
.dash_menu-arrow {
  background-color: rgba(218,174,73,.1) !important;
  border: 1px solid rgba(218,174,73,.2) !important;
  border-radius: 50% !important;
  width: 32px !important; height: 32px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  cursor: pointer !important;
  flex-shrink: 0 !important;
  transition: background .2s !important;
}
.dash_menu-arrow:hover {
  background-color: rgba(218,174,73,.2) !important;
}
/* Override hardcoded fill="#1E1E1E" on SVG */
.dash_menu-arrow svg { fill: var(--g) !important; }
.dash_menu-arrow svg path { fill: var(--g) !important; }
.dash_menu-arrow.disabled { opacity: .3 !important; pointer-events: none !important; }

/* ── hr divider in head ── */
.dash_head .hr_line,
.dash_head hr {
  border-color: rgba(218,174,73,.12) !important;
  opacity: 1 !important;
}

/* ── Dashboard body ── */
.dash_body {
  background-color: transparent !important;
}

/* ── Overview cards container ── */
.dash_overview-wrap {
  display: grid !important;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)) !important;
  gap: 16px !important;
}

/* ── Each stat card ── */
.dash_overview-card {
  background-color: var(--bg2) !important;
  border: 1px solid rgba(218,174,73,.14) !important;
  border-radius: 20px !important;
  padding: 24px 20px !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  text-align: center !important;
  gap: 10px !important;
  text-decoration: none !important;
  transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease !important;
  box-shadow: 0 2px 12px rgba(0,0,0,.25) !important;
}
.dash_overview-card:hover {
  transform: translateY(-3px) !important;
  border-color: rgba(218,174,73,.35) !important;
  box-shadow: 0 8px 28px rgba(218,174,73,.1) !important;
  text-decoration: none !important;
}

/* ── Icon area in stat card ── */
.dash_overview-icon {
  width: 56px !important; height: 56px !important;
  border-radius: 16px !important;
  background: linear-gradient(135deg, rgba(184,139,60,.15), rgba(218,174,73,.1)) !important;
  border: 1px solid rgba(218,174,73,.2) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  position: relative !important;
}
/* The decorative <span> inside icon */
.dash_overview-icon > span {
  position: absolute !important;
  inset: 0 !important;
  border-radius: inherit !important;
  background: radial-gradient(circle at 30% 30%, rgba(218,174,73,.12), transparent) !important;
}
/* SVG icon */
.dash_overview-icon svg {
  width: 26px !important; height: 26px !important;
  fill: var(--g) !important;
  color: var(--g) !important;
  position: relative !important;
  z-index: 1 !important;
  filter: drop-shadow(0 0 6px rgba(218,174,73,.3)) !important;
}

/* ── Stat number ── */
.dash_overview-heading {
  color: var(--g) !important;
  font-size: 1.5rem !important;
  font-weight: 700 !important;
  margin: 0 !important;
  line-height: 1.2 !important;
}
.dash_overview-heading sar,
.dash_overview-heading sar::before {
  font-size: .85em !important;
  color: var(--txm) !important;
}

/* ── Stat label ── */
.dash_overview-btn {
  color: var(--txs) !important;
  font-size: 13px !important;
  font-weight: 500 !important;
}

/* ── Other dashboard sub-pages (orders, downloads, etc.) ── */
.dash_body .card,
.dash_body .bg-white,
.dash_body [class*="order-card"],
.dash_body [class*="ticket-card"] {
  background-color: var(--bg2) !important;
  border-color: rgba(218,174,73,.14) !important;
  color: var(--txt) !important;
}
.dash_body table {
  background-color: transparent !important;
}
.dash_body thead th {
  background-color: var(--bg3) !important;
  color: var(--g) !important;
  border-color: rgba(218,174,73,.14) !important;
}
.dash_body tbody tr {
  border-color: rgba(218,174,73,.08) !important;
}
.dash_body tbody tr:hover {
  background-color: rgba(218,174,73,.04) !important;
}
.dash_body td, .dash_body th {
  color: var(--txs) !important;
  border-color: rgba(218,174,73,.1) !important;
}
.dash_body .badge { font-weight: 600 !important; }

/* Status badges in orders */
.dash_body .badge-success, .dash_body .bg-success { background-color: rgba(34,197,94,.15) !important; color: #4ade80 !important; }
.dash_body .badge-warning, .dash_body .bg-warning { background-color: rgba(218,174,73,.15) !important; color: var(--g) !important; }
.dash_body .badge-danger,  .dash_body .bg-danger  { background-color: rgba(220,53,69,.15) !important; color: #e07070 !important; }
.dash_body .badge-info,    .dash_body .bg-info    { background-color: rgba(99,179,237,.15) !important; color: #7ec8e3 !important; }

/* Pagination */
.dash_body .page-item .page-link {
  background-color: var(--bg3) !important;
  border-color: rgba(218,174,73,.15) !important;
  color: var(--txs) !important;
}
.dash_body .page-item.active .page-link {
  background: linear-gradient(135deg, var(--gx), var(--g)) !important;
  border-color: transparent !important;
  color: #0a0700 !important;
}

/* ── Mobile: stack cards 2-col ── */
@media (max-width: 767px) {
  .dash_overview-wrap {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 12px !important;
  }
  .dash_overview-card { padding: 18px 12px !important; }
  .dash_overview-heading { font-size: 1.2rem !important; }
  .dash_overview-icon { width: 46px !important; height: 46px !important; }
  .dash_overview-icon svg { width: 22px !important; height: 22px !important; }
}
