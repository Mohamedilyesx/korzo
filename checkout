    background-color: var(--g) !important;
    color: #000 !important;
    font-weight: 700 !important;
  }

  /* Logo */
  nav.navbar.navbar3 .navbar-brand img,
  .custom-navbar .navbar-brand img {
    filter: none !important;
    opacity: 1 !important;
  }

  /* Interactive block */
  .jawak-interactive-shell {
    grid-template-columns: 1fr !important;
    max-width: 660px !important;
  }
  .jawak-media-card,
  .jawak-media-card video { min-height: 260px !important; }

