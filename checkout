.jwk-item:hover { color: #f5e9aa; }

.jwk-sep {
  display: inline-flex;
  align-items: center;
  height: 100%;
  padding: 0 4px;
  color: rgba(218,174,73,.6);
  font-size: 8px;
  white-space: nowrap;
  flex: 0 0 auto;
}

#jwkX {
  flex: 0 0 auto;
  width: 34px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0; margin: 0;
  opacity: .55;
  transition: opacity .2s, color .2s;
  color: #c9a84c;
