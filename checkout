  --gold-pale:     #fff3cf;
  --gold-muted:    #c9a25e;
  --gold-dim:      #e8dfc0;
  --gold-dark:     #0A0800;
  --text-main:     #f0ead8;
  --text-sub:      #c8bfa8;
