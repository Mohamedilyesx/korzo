        [dir=ltr] .login_back-home {
            left: auto;
            right: var(--x-pos);
            transform: scale(-1);
        }

        .login_back-home:hover {
            color: var(--main-color-one);
        }

        .checkout{
            padding: 32px 0;
            background: #F1F1F1;
        }
        .checkout > .container{
            max-width: 980px;
        }
        .row{gap: 0;}
        .checkout .form-control{
            padding: 10px 14px;
            border-radius: 8px;
            box-shadow: none !important;
        }
        .checkout .form-select{
            padding-top: 10px;
            padding-bottom: 10px;
            border-radius: 8px;
            box-shadow: none !important;
        }
        .checkout .form-control:focus,
        .checkout .form-select:focus{
            border-color: var(--main-color-one);
        }
        [dir=rtl] .input-group .form-control{
            border-radius: 8px 0 0 8px !important
