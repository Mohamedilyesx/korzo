   ABOUT BOX — استبدال بالـ interactive block
========================================================= */
.xc-about-section,
[class*="about-section"],
[class*="about-area"] {
  background-color: var(--bg-dark) !important;
  padding: 48px 0 !important;
}

/* =========================================================
   GLOBAL DARK OVERRIDES — منصة تجار
========================================================= */

/* Header */
.xc-header,
[class*="header-wrapper"],
[class*="top-bar"],
.xc-navbar {
  background-color: rgba(10, 8, 0, 0.92) !important;
  backdrop-filter: blur(14px) !important;
  -webkit-backdrop-filter: blur(14px) !important;
  border-bottom: 1px solid rgba(201,162,95,.16) !important;
}

/* Nav links */
.xc-header a,
.xc-navbar a,
[class*="nav-link"],
[class*="menu-item"] a {
  color: var(--text-main) !important;
}

.xc-header a:hover,
.xc-navbar a:hover,
[class*="nav-link"]:hover {
  color: var(--gold) !important;
}

/* Buttons */
.xc-btn,
.xc-button,
[class*="btn-primary"],
[class*="add-to-cart"],
[class*="buy-now"],
button[type="submit"],
.btn-main {
  background: linear-gradient(180deg, #daae49 0%, #c79b39 100%) !important;
  color: #0A0800 !important;
  border: none !important;
  font-weight: 700 !important;
}

.xc-btn:hover,
.xc-button:hover,
[class*="btn-primary"]:hover,
[class*="add-to-cart"]:hover {
  background: linear-gradient(180deg, #f0d080 0%, #daae49 100%) !important;
  color: #0A0800 !important;
}

/* Input fields */
input, textarea, select,
[class*="form-control"],
[class*="input-field"],
.xc-input {
  background-color: var(--bg-surface) !important;
  border: 1px solid rgba(218,174,73,.22) !important;
  color: var(--text-main) !important;
  border-radius: 10px !important;
}

input::placeholder,
textarea::placeholder {
  color: var(--text-muted) !important;
}

input:focus, textarea:focus, select:focus,
[class*="form-control"]:focus {
  border-color: rgba(218,174,73,.50) !important;
  box-shadow: 0 0 0 3px rgba(218,174,73,.12) !important;
  outline: none !important;
}

/* Product price */
[class*="price"],
.xc-price,
.price-main,
.sale-price {
  color: var(--gold) !important;
  font-weight: 700 !important;
}

[class*="old-price"],
[class*="original-price"],
.price-old {
  color: var(--text-muted) !important;
  text-decoration: line-through !important;
}

/* Product title */
[class*="product-title"],
[class*="product-name"],
.xc-product-name {
  color: var(--text-main) !important;
}

/* Product description */
[class*="product-desc"],
[class*="product-description"],
.xc-product-desc {
  color: var(--text-sub) !important;
}

/* Category title */
[class*="category-title"],
[class*="section-title"],
.xc-section-title {
  color: var(--gold-pale) !important;
}

/* Breadcrumbs */
[class*="breadcrumb"] a { color: var(--text-sub) !important; }
[class*="breadcrumb"] .active { color: var(--gold) !important; }

/* Footer */
footer,
.xc-footer,
[class*="footer-"] {
  background-color: #0f0e0b !important;
  border-top: 1px solid rgba(218,174,73,.14) !important;
  color: var(--text-sub) !important;
}

footer a,
.xc-footer a { color: var(--text-sub) !important; }
footer a:hover,
.xc-footer a:hover { color: var(--gold) !important; }

/* Dividers */
hr, [class*="divider"] {
  border-color: rgba(218,174,73,.12) !important;
}

/* Badges & tags */
[class*="badge"],
[class*="tag-"],
.xc-badge {
  background: linear-gradient(180deg, #18140e 0%, #221a12 100%) !important;
  border: 1px solid rgba(218,174,73,.28) !important;
  color: var(--gold) !important;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg-dark); }
::-webkit-scrollbar-thumb {
  background: rgba(218,174,73,.3);
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover { background: rgba(218,174,73,.55); }

/* Selection */
::selection {
  background: rgba(218,174,73,.25);
  color: var(--gold-pale);
}

