<script>
    $(document).ready(function() {
        var logout_btn_width = $('.dash_logout span').width();
        $('.dash_logout').css({'--logout-txt-width': logout_btn_width + 22 + 'px'});


        const slider = document.querySelector('.dash_menu-list');
        const leftArrow = document.querySelector(".dash_menu-left-arrow");
        const rightArrow = document.querySelector(".dash_menu-right-arrow");
        let isDown = false;
        let startX;
        let scrollLeft;

        slider.addEventListener('mousedown', (e) => {
            isDown = true;
            startX = e.pageX - slider.offsetLeft;
            scrollLeft = slider.scrollLeft;
        });
        document.addEventListener('mouseup', () => {isDown = false;});
        slider.addEventListener('mousemove', (e) => {
            if(!isDown) return;
            e.preventDefault();
            const walk = ((e.pageX - slider.offsetLeft) - startX) * 3;
            slider.scrollLeft = scrollLeft - walk;
        });

        document.querySelectorAll(".dash_menu-arrow").forEach(function(arrow) {
            arrow.addEventListener("click", function(e) {
                slider.scrollLeft = this.classList.contains("dash_menu-left-arrow") ? slider.scrollLeft - 110 : slider.scrollLeft + 110;
            });
        });

        slider.addEventListener('scroll', updateArrowState);

        function updateArrowState() {
            const isRtl = document.documentElement.getAttribute('dir') === 'rtl';
            const scrollLeft = slider.scrollLeft;
            const maxScrollLeft = slider.scrollWidth - slider.clientWidth;

            if (isRtl) {
                leftArrow.classList.toggle("disabled", scrollLeft + maxScrollLeft <= 5);
                rightArrow.classList.toggle("disabled", scrollLeft >= 0);
            } else {
                leftArrow.classList.toggle("disabled", scrollLeft <= 0);
                rightArrow.classList.toggle("disabled", scrollLeft >= maxScrollLeft);
            }
        }

        updateArrowState();
    });
</script>
