/* =========================================================
   DARK MODE BASE
========================================================= */
:root {
  --bg-dark:       #1a1815;
  --bg-card:       #1f1c19;
  --bg-surface:    #242018;
  --bg-surface-2:  #2a261f;
  --border-gold:   rgba(218,174,73,.18);
  --border-gold-2: rgba(218,174,73,.30);
  --gold:          #daae49;
  --gold-light:    #f0d080;
  --gold-pale:     #fff3cf;
  --gold-muted:    #c9a25e;
  --gold-dim:      #e8dfc0;
  --gold-dark:     #0A0800;
  --text-main:     #f0ead8;
  --text-sub:      #c8bfa8;
  --text-muted:    #908778;
  --radius-card:   22px;
  --shadow-card:   0 14px 36px rgba(0,0,0,.45);
}

/* Force dark background on entire store */
body,
.xc-main,
.main-content,
[class*="page-wrapper"],
[class*="layout-wrapper"],
.xc-content,
#main,
.xc-storefront {
  background-color: var(--bg-dark) !important;
  color: var(--text-main) !important;
}

/* =========================================================
   DARK SURFACES — Cards, Sections
========================================================= */
.xc-product-card,
.xc-card,
[class*="card-item"],
[class*="product-card"],
[class*="section-card"],
.xc-category-one__item-inner,
[class*="category-item"],
.xc-checkout-box,
