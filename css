.new_address-bar:hover { border-color: rgba(218,174,73,.35) !important; }
.saved_address-text { color: var(--txt) !important; }
.new_address-bar label i { color: var(--g) !important; }

/* Address / form wraps */
.edit_address-wrap,
.address_form-wrap {
  background-color: var(--bg3) !important;
  border-color: rgba(218,174,73,.16) !important;
