  padding: 48px 0 0;
  margin-top: 8px;
  position: relative;
  z-index: 1;
}

/* الشبكة الثلاثية */
#jwk-footer-extra .jwk-fe-grid {
  display: grid;
  grid-template-columns: 1.3fr 1fr 1fr;
  gap: 32px 48px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ──────────────────────────────────────────────────────────────────────
   12A. عناوين الأعمدة — col titles
────────────────────────────────────────────────────────────────────── */

.jwk-fe-col-title {
  font-size: 13px !important;
  font-weight: 800 !important;
  letter-spacing: 0.06em !important;
  text-transform: uppercase !important;
  color: transparent !important;
  background: linear-gradient(135deg, #c9922a, #daae49, #f0d878) !important;
  -webkit-background-clip: text !important;
  background-clip: text !important;
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
  margin-bottom: 20px !important;
  padding-bottom: 12px !important;
  position: relative !important;
  border-bottom: none !important;
  width: 100% !important;
}

.jwk-fe-col-title::after {
  content: '' !important;
  position: absolute !important;
  bottom: 0 !important;
  right: 0 !important;
  width: 36px !important;
  height: 2px !important;
  background: linear-gradient(90deg, #daae49, transparent) !important;
  border-radius: 2px !important;
}

.jwk-fe-col-title svg {
  width: 16px !important;
  height: 16px !important;
  stroke: #daae49 !important;
  fill: none !important;
  flex-shrink: 0 !important;
}

/* ──────────────────────────────────────────────────────────────────────
   12B. عمود "اتصل بنا" — contact column
────────────────────────────────────────────────────────────────────── */

.jwk-contact-card {
  background: linear-gradient(145deg, rgba(218,174,73,.05), rgba(185,136,40,.02));
  border: 1px solid rgba(218,174,73,.14);
  border-radius: 16px;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.jwk-contact-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.jwk-contact-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(218,174,73,.1);
  border: 1px solid rgba(218,174,73,.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.jwk-contact-icon svg {
  width: 16px !important;
  height: 16px !important;
  stroke: #daae49 !important;
  fill: none !important;
}

.jwk-contact-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.jwk-contact-label {
  font-size: 11px !important;
  color: #6a6055 !important;
  font-weight: 600 !important;
  letter-spacing: 0.05em !important;
  text-transform: uppercase !important;
  line-height: 1.4 !important;
}

.jwk-contact-value {
  font-size: 13.5px !important;
  color: #c8bfa8 !important;
  font-weight: 500 !important;
  line-height: 1.5 !important;
}

.jwk-contact-value a {
  color: #c8bfa8 !important;
  font-size: 13.5px !important;
  display: inline !important;
  transition: color .2s !important;
  padding: 0 !important;
}

.jwk-contact-value a:hover {
  color: #f0d878 !important;
  padding: 0 !important;
}

/* زر واتساب */
.jwk-wa-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8px !important;
  padding: 11px 20px !important;
  border-radius: 999px !important;
  background: linear-gradient(135deg, #1a3a1f, #1f4a24) !important;
  border: 1px solid rgba(45,214,107,.25) !important;
  color: #4ade80 !important;
  font-size: 13px !important;
  font-weight: 700 !important;
  text-decoration: none !important;
  transition: all .25s ease !important;
  margin-top: 4px !important;
  width: 100% !important;
}

.jwk-wa-btn:hover {
  background: linear-gradient(135deg, #1f4a24, #25562a) !important;
  border-color: rgba(45,214,107,.45) !important;
  color: #86efac !important;
  box-shadow: 0 6px 18px rgba(45,214,107,.12) !important;
  transform: translateY(-2px) !important;
  padding-right: 20px !important;
}

.jwk-wa-btn svg {
  width: 16px !important;
  height: 16px !important;
  fill: currentColor !important;
  stroke: none !important;
}

/* ──────────────────────────────────────────────────────────────────────
   12C. عمود "روابط هامة" — important links column
────────────────────────────────────────────────────────────────────── */

.jwk-imp-links {
  display: flex !important;
  flex-direction: column !important;
  gap: 2px !important;
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

.jwk-imp-links li {
  border-bottom: none !important;
  padding: 0 !important;
}

.jwk-imp-link-item {
  display: flex !important;
  align-items: center !important;
  gap: 10px !important;
  padding: 9px 12px !important;
  border-radius: 10px !important;
  color: #b8aa94 !important;
  font-size: 13.5px !important;
  font-weight: 500 !important;
  text-decoration: none !important;
  transition: all .22s ease !important;
  border: 1px solid transparent !important;
  position: relative !important;
  overflow: hidden !important;
  width: 100% !important;
}

.jwk-imp-link-item::before {
  content: '' !important;
  position: absolute !important;
  inset: 0 !important;
  background: linear-gradient(90deg, rgba(218,174,73,.06), transparent) !important;
  opacity: 0 !important;
  transition: opacity .22s !important;
  border-radius: inherit !important;
}

.jwk-imp-link-item:hover {
  color: #f0d878 !important;
  border-color: rgba(218,174,73,.18) !important;
  background: rgba(218,174,73,.04) !important;
  padding-right: 16px !important;
}

.jwk-imp-link-item:hover::before {
  opacity: 1 !important;
}

.jwk-link-icon {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  background: rgba(218,174,73,.08);
  border: 1px solid rgba(218,174,73,.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all .22s ease;
}

.jwk-imp-link-item:hover .jwk-link-icon {
  background: rgba(218,174,73,.14);
  border-color: rgba(218,174,73,.3);
}

.jwk-link-icon svg {
  width: 13px !important;
  height: 13px !important;
  stroke: #daae49 !important;
  fill: none !important;
}

/* ──────────────────────────────────────────────────────────────────────
   12D. عمود "ساعات العمل" — Night Schedule الفكرة الجبارة ✦
────────────────────────────────────────────────────────────────────── */

.jwk-night-schedule {
  background: linear-gradient(145deg, #0e0c08, #15120a);
  border: 1px solid rgba(218,174,73,.18);
  border-radius: 18px;
  overflow: hidden;
  position: relative;
}

.jwk-night-schedule::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(218,174,73,.5) 50%, transparent);
}

/* رأس الجدول مع النقطة الخضراء النابضة */
.jwk-schedule-header {
  padding: 14px 18px;
  background: linear-gradient(135deg, rgba(218,174,73,.08), rgba(185,136,40,.04));
  border-bottom: 1px solid rgba(218,174,73,.1);
  display: flex;
  align-items: center;
  gap: 10px;
}

.jwk-schedule-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 8px rgba(34,197,94,.5);
  animation: jwkPulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes jwkPulse {
  0%, 100% { box-shadow: 0 0 8px rgba(34,197,94,.5); }
  50%       { box-shadow: 0 0 16px rgba(34,197,94,.8); }
}

.jwk-schedule-status {
  font-size: 12px !important;
  font-weight: 700 !important;
  color: #22c55e !important;
  letter-spacing: 0.04em !important;
  text-transform: uppercase !important;
}

/* صفوف الجدول */
.jwk-schedule-rows {
  padding: 12px 0;
}

.jwk-schedule-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 18px;
  transition: background .18s ease;
  gap: 12px;
}

.jwk-schedule-row:hover {
  background: rgba(218,174,73,.04);
}

/* تمييز اليوم الحالي بخط ذهبي على الجانب */
.jwk-schedule-row.today {
  background: rgba(218,174,73,.07);
  position: relative;
}

.jwk-schedule-row.today::after {
  content: '' !important;
  position: absolute !important;
  right: 0 !important;
  top: 0 !important;
  bottom: 0 !important;
  width: 2px !important;
  background: linear-gradient(180deg, transparent, #daae49, transparent) !important;
}

.jwk-day-name {
  font-size: 12.5px !important;
  color: #8a8070 !important;
  font-weight: 500 !important;
  flex: 1 !important;
}

.jwk-schedule-row.today .jwk-day-name {
  color: #f0d878 !important;
  font-weight: 700 !important;
}

.jwk-day-time {
  font-size: 12px !important;
  color: #6a6055 !important;
  font-weight: 600 !important;
  direction: ltr !important;
  unicode-bidi: embed !important;
  white-space: nowrap !important;
  background: rgba(218,174,73,.07) !important;
  padding: 3px 8px !important;
  border-radius: 6px !important;
  border: 1px solid rgba(218,174,73,.1) !important;
}

.jwk-schedule-row.today .jwk-day-time {
  color: #daae49 !important;
  background: rgba(218,174,73,.14) !important;
  border-color: rgba(218,174,73,.28) !important;
}

.jwk-day-time.closed {
