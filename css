/* ──────────────────────────────────────────────────────────────────────
   10. FOOTER BOTTOM BAR — شريط حقوق الملكية
────────────────────────────────────────────────────────────────────── */

.store-section.footer-store-section .footer-bottom,
.store-section.footer-store-section [class*="copyright"],
footer .footer-bottom,
