/* ──────────────────────────────────────────────────────────────────────
   2. FOOTER WRAPPER — الهيكل والخلفية
────────────────────────────────────────────────────────────────────── */

.store-section.footer-store-section,
footer,
.footer-area {
  background: transparent !important;
  position: relative !important;
  isolation: isolate !important;
}

/* خلفية التدرج الداكن الفاخر */
.store-section.footer-store-section::after,
footer::after {
  content: '' !important;
  position: absolute !important;
  inset: 0 !important;
  z-index: -1 !important;
  background:
    radial-gradient(ellipse 80% 40% at 50% -10%, rgba(218,174,73,.09) 0%, transparent 70%),
    radial-gradient(ellipse 50% 60% at 0% 100%, rgba(185,136,40,.06) 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 100% 100%, rgba(218,174,73,.06) 0%, transparent 55%),
    linear-gradient(180deg, #100f0c 0%, #0d0b08 40%, #080705 100%) !important;
  pointer-events: none !important;
}

/* الخط الذهبي العلوي المضيء */
.store-section.footer-store-section::before,
footer::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important; left: 0 !important; right: 0 !important;
  height: 1px !important;
  z-index: 2 !important;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(185,136,40,.4) 15%,
    rgba(218,174,73,.85) 35%,
    rgba(240,216,120,1) 50%,
    rgba(218,174,73,.85) 65%,
    rgba(185,136,40,.4) 85%,
    transparent 100%
  ) !important;
  box-shadow: 0 0 28px rgba(218,174,73,.25), 0 0 6px rgba(240,216,120,.3) !important;
}

/* ──────────────────────────────────────────────────────────────────────
   3. FOOTER CONTAINER — المحتوى الداخلي
────────────────────────────────────────────────────────────────────── */

.store-section.footer-store-section .container,
.store-section.footer-store-section .row,
footer .container,
footer .row {
  position: relative !important;
  z-index: 1 !important;
}

.store-section.footer-store-section > .container,
footer > .container {
