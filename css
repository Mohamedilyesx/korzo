/* ── Login modal (guest checkout) ── */
.login_modal, .checkout_page .modal-content {
  background-color: var(--bg2) !important;
  border-color: rgba(218,174,73,.2) !important;
}

/* ── Select2 on checkout ── */
.checkout_page .select2-container--default .select2-selection--single {
  background-color: var(--bg3) !important;
  border-color: rgba(218,174,73,.18) !important;
