}
.payment_tab:hover { border-color: rgba(218,174,73,.4) !important; }
.payment_tab.active,
.payment_tab[aria-selected="true"] {
  border-color: var(--g) !important;
  background-color: rgba(218,174,73,.06) !important;
}
.payment_name { color: var(--txt) !important; font-weight: 500 !important; }
.payment_tab .img img { filter: brightness(.85) !important; }

/* ── Shipping method cards (lazy-loaded) ── */
.shipping_card {
  background-color: var(--bg3) !important;
  border: 1px solid rgba(218,174,73,.16) !important;
  border-radius: 12px !important;
  cursor: pointer !important;
