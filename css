   كود الفوتر الكامل: التصميم + روابط هامة + اتصل بنا + جدول العمل
   ══════════════════════════════════════════════════════════════════════ */

/* ──────────────────────────────────────────────────────────────────────
   1. VARIABLES
────────────────────────────────────────────────────────────────────── */
:root {
  --g:    #daae49;
  --gl:   #f0d878;
  --gd:   #c9922a;
  --gx:   #b88b3c;
  --bg:   #1a1815;
  --bg2:  #1f1c19;
  --bg3:  #242018;
  --bg4:  #141109;
  --txt:  #f0ead8;
  --txs:  #c8bfa8;
  --txm:  #908778;
