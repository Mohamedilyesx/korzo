/* Headings */
h1, h2, h3, h4, h5, h6 { color: var(--txt) !important; }

/* Links */
a { color: var(--txs); text-decoration: none; transition: color .2s var(--ease); }
a:hover { color: var(--g); }

/* Scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg4); }
::-webkit-scrollbar-thumb { background: rgba(218,174,73,.3); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(218,174,73,.5); }

/* Inputs */
input:not([type="range"]), textarea, select {
  background-color: var(--bg3) !important;
  border: 1px solid rgba(218,174,73,.2) !important;
  color: var(--txt) !important;
  border-radius: 10px !important;
}
input:focus, textarea:focus, select:focus {
  border-color: rgba(218,174,73,.5) !important;
  outline: none !important;
  box-shadow: 0 0 0 3px rgba(218,174,73,.08) !important;
}
input::placeholder, textarea::placeholder { color: var(--txm) !important; }

/* HR lines */
hr {
  border-color: rgba(218,174,73,.12) !important;
  opacity: 1 !important;
}

/* Bootstrap overrides — background-color ONLY, never background shorthand */
.bg-white  { background-color: var(--bg2) !important; }
.bg-light  { background-color: var(--bg3) !important; }
.text-dark { color: var(--txt) !important; }
.text-muted, .text-secondary { color: var(--txm) !important; }
.border    { border-color: var(--bdr) !important; }
.border-top    { border-top-color: var(--bdr) !important; }
.border-bottom { border-bottom-color: var(--bdr) !important; }

/* ============================================================
   PROMO BAR — #jwk-bar (built by JS)
   Fixed at absolute top, z:100000
   ============================================================ */
.promobar, .promobar.container-fluid { display: none !important; }

#jwk-bar {
  position: fixed !important;
  top: 0 !important; left: 0 !important; right: 0 !important;
  height: var(--bar-h);
  z-index: 100000 !important;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: linear-gradient(135deg, #0e0901, #1c1200, #221400, #0e0901);
  border-bottom: 1px solid rgba(218,174,73,.22);
  box-shadow: 0 2px 16px rgba(0,0,0,.6), inset 0 1px 0 rgba(218,174,73,.08);
  box-sizing: border-box;
}
#jwk-bar::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(218,174,73,.6) 50%, transparent);
  pointer-events: none;
}
#jwk-mask {
  flex: 1; height: 100%; overflow: hidden;
  -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
  mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
}
#jwk-track {
  display: inline-flex; flex-wrap: nowrap;
  height: 100%; align-items: center;
  white-space: nowrap; will-change: transform;
}
.jwk-item {
  display: inline-flex; align-items: center;
  padding: 0 26px; color: #e8dfc0;
  font-size: 13.5px; font-weight: 500; white-space: nowrap;
  direction: rtl; transition: color .2s;
}
.jwk-item:hover { color: #f5e9aa; }
.jwk-sep {
  display: inline-flex; align-items: center;
  padding: 0 4px; color: rgba(218,174,73,.45); font-size: 9px;
}
#jwk-close {
  flex: 0 0 38px; width: 38px; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: transparent; border: none; cursor: pointer;
  color: rgba(218,174,73,.6); font-size: 15px;
  transition: color .2s, opacity .2s; opacity: .65;
}
#jwk-close:hover { color: var(--g); opacity: 1; }

/* ============================================================
   NAVBAR — fixed below promo bar, glass on scroll
   ============================================================ */
nav.navbar.navbar3, .custom-navbar,
.navbar.navbar3 {
  position: fixed !important;
  top: var(--bar-h) !important;
  left: 0 !important; right: 0 !important;
  z-index: 9999 !important;
  background-color: transparent !important;
  border-bottom: none !important;
  box-shadow: none !important;
  transition: background-color .3s ease, backdrop-filter .3s ease,
              box-shadow .3s ease, top .3s ease !important;
}
/* Bar closed → navbar snaps to top */
body.jwk-bar-closed nav.navbar.navbar3,
body.jwk-bar-closed .custom-navbar,
body.jwk-bar-closed .navbar.navbar3 {
  top: 0 !important;
}
/* Scrolled → dark glass */
nav.navbar.navbar3.scrolled, .custom-navbar.scrolled,
.navbar.navbar3.scrolled {
  background-color: rgba(10,7,0,.93) !important;
  backdrop-filter: blur(18px) saturate(1.4) !important;
  -webkit-backdrop-filter: blur(18px) saturate(1.4) !important;
  border-bottom: 1px solid rgba(218,174,73,.15) !important;
  box-shadow: 0 4px 28px rgba(0,0,0,.5) !important;
}

/* Navbar text/icons */
nav.navbar.navbar3 .navbar-nav li a,
nav.navbar.navbar3 .nav-link,
nav.navbar.navbar3 a,
.custom-navbar .nav-link,
.custom-navbar a {
  color: #fff !important;
  font-weight: 600;
  transition: color .2s !important;
}
nav.navbar.navbar3 .navbar-nav li a:hover,
nav.navbar.navbar3 .nav-link:hover,
.custom-navbar .nav-link:hover,
.custom-navbar a:hover { color: var(--g) !important; }

nav.navbar.navbar3 svg, nav.navbar.navbar3 i,
.custom-navbar svg, .custom-navbar i { color: #fff !important; }
.icon-notification { background-color: var(--g) !important; color: #000 !important; }

/* Breadcrumb */
.breadcrumb { background-color: transparent !important; }
.breadcrumb-item a { color: var(--txm) !important; }
.breadcrumb-item.active { color: var(--txs) !important; }
.breadcrumb-item + .breadcrumb-item::before { color: var(--txm) !important; }

