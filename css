section { background-color: transparent !important; }
.container { background-color: transparent !important; }

/* ============================================================
   GLOBAL BUTTONS
   ============================================================ */
.btn-primary, [class*="btn-primary"] {
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl)) !important;
