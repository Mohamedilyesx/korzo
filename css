/* Phone/Email input screen */
.inputForm--screen,
.inputNameForm {
  background-color: transparent !important;
}
.account-form {
  background-color: transparent !important;
}
.form-title { color: var(--txt) !important; }
.form-sub   { color: var(--txm) !important; }

/* Toggle: "تسجيل الدخول بالبريد / الجوال" text buttons */
.btn-text {
  color: var(--g) !important;
  background: none !important;
  border: none !important;
  cursor: pointer !important;
  text-decoration: underline !important;
  text-underline-offset: 3px !important;
}
.btn-text:hover { color: #f0d878 !important; }

/* Submit button in guest form */
.submit-btn {
  background: linear-gradient(135deg, var(--gx), var(--g), var(--gl)) !important;
  border: none !important;
  color: #0a0700 !important;
  font-weight: 800 !important;
  border-radius: 10px !important;
