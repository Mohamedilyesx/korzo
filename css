}

/* ──────────────────────────────────────────────────────────────────────
   4. FOOTER HEADINGS — عناوين الأقسام بتأثير الذهب
────────────────────────────────────────────────────────────────────── */

.store-section.footer-store-section h4,
.store-section.footer-store-section h5,
.store-section.footer-store-section h3,
.store-section.footer-store-section .footer-widget-title,
.store-section.footer-store-section .widget-title,
