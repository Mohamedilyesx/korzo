}
.page-header h1, .page-header h2,
.breadcrumb-area h1, .breadcrumb-area h2 { color: var(--txt) !important; }

/* ============================================================
   SECTIONS — general dark backgrounds
   ============================================================ */
.widgetArea, section.widgetArea {
  background-color: transparent !important;
}
.product-cat-slider-area, .product-type-area {
  background-color: var(--bg) !important;
}
.section-head .section-title { color: var(--txt) !important; }
