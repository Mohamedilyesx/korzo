  border: none !important;
  color: #0a0700 !important;
  font-weight: 800 !important;
  border-radius: 12px !important;
  box-shadow: 0 6px 22px rgba(218,174,73,.25) !important;
}
.checkout .btn-lg.btn-main:hover,
.checkout_page .btn-lg.btn-main:hover { transform: translateY(-2px) !important; }

/* ── Guest login modal (phone/email/OTP screens) ── */
.checkout_page .modal-content,
.checkout_page .login_modal .modal-content {
  background-color: var(--bg2) !important;
  border: 1px solid rgba(218,174,73,.18) !important;
  border-radius: 20px !important;
}
/* Back-home arrow inside modal */
